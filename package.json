{
  "name": "gittydocs-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter gittydocs build",
    "build:web": "bun run --filter @gittydocs/web-runtime build",
    "changeset": "changeset",
    "ci": "bun run check && bun run build",
    "dev:web": "bun run --filter @gittydocs/web-runtime dev",
    "dev:docs": "gittydocs dev docs",
    "gen:schemajson": "bun run --filter @gittydocs/web-runtime generate:config-schema",
    "build:docs": "gittydocs build docs",
    "check": "bun run --filter '*' check",
    "check:fix": "bun run --filter '*' check:fix",
    "publish-ci": "bun run check && bun run build && changeset publish",
    "typecheck": "bun run --filter gittydocs typecheck",
    "cleanmod": "rm -rf node_modules && find packages -type d -name node_modules -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0"
  }
}
