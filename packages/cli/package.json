{
  "name": "gittydocs",
  "version": "0.0.4",
  "description": "Turn a GitHub folder of Markdown/MDX into a fast, searchable docs site",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gittydocs": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "bun run typecheck",
    "prepack": "bun run sync:web-runtime",
    "sync:web-runtime": "bun run scripts/sync-web-runtime.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}
