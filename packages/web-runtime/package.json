{
  "name": "@gittydocs/web-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Gittydocs web runtime template",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently --raw \"bun run dev:velite\" \"bun run dev:vite\"",
    "dev:vite": "sleep 1 && vike dev",
    "dev:velite": "bun run prepare:docs && bunx velite dev",
    "build": "bun run prepare:docs && bunx velite build && bun run velite:routes && vike build",
    "preview": "NODE_ENV=production bun run dist/server/index.mjs",
    "preview-static": "vike preview",
    "check": "tsc --noemit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "cleanmods": "rm -rf node_modules",
    "icon": "iconmate --folder src/assets/icons/",
    "prepare:docs": "bun run scripts/prepare-docs.ts",
    "generate:config-schema": "bun run scripts/generate-config-schema.ts",
    "velite:routes": "bun run scripts/gen-velite-routes.ts"
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
    "@corvu/drawer": "^0.2.4",
    "@kobalte/core": "^0.13.12",
    "@shikijs/rehype": "^4.3.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@vikejs/hono": "^0.2.1",
    "bagon-hooks": "^0.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "flexsearch": "^0.8.212",
    "hono": "^4.12.30",
    "jsonc-parser": "^3.3.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "solid-js": "1.9.14",
    "solid-jsx": "^1.1.4",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.6.0",
    "vike": "^0.4.260",
    "vike-metadata-solid": "^1.0.5",
    "vike-solid": "^0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@blankeos/vike-routegen": "^0.0.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/flexsearch": "^0.7.42",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "iconmate": "^1.2.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "velite": "^0.4.0",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-solid-svg": "^0.8.1"
  },
  "trustedDependencies": []
}
